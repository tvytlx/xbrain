{
  "name": "xbrain",
  "version": "0.1.1",
  "type": "module",
  "description": "A local-first multi-agent chat TUI for Codex, Claude Code, and Gemini.",
  "author": "Xiao Tan <tvytlx@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tvytlx/xbrain.git"
  },
  "homepage": "https://github.com/tvytlx/xbrain",
  "bugs": {
    "url": "https://github.com/tvytlx/xbrain/issues"
  },
  "bin": {
    "xbrain": "./bin/xbrain.js"
  },
  "files": [
    "bin",
    "src",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "scripts": {
    "dev": "node --experimental-strip-types src/index.ts",
    "start": "yarn dev",
    "test": "node --experimental-strip-types --test tests/*.test.ts",
    "smoke": "node --experimental-strip-types scripts/smoke.ts",
    "pack:check": "npm pack --dry-run"
  },
  "dependencies": {
    "ink": "^6.8.0",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
